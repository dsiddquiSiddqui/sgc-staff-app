{
  "expo": {
    "name": "SGC Digital ID",
    "slug": "sgc-digital-id",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "sgcdigitalid",
    "icon": "./assets/images/favis.png",
    "updates": {
      "enabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-bg.jpg",
          "resizeMode": "cover",
          "backgroundColor": "#111111"
        }
      ]
    ],
    "android": {
      "package": "com.sgc.digitalid",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/favis.png",
        "backgroundColor": "#111111"
      }
    },
    "ios": {
      "bundleIdentifier": "com.sgc.digitalid"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "919f6cb2-2045-4916-8944-b751b7464278"
      }
    }
  }
}
